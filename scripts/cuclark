#!/usr/bin/env python3
"""
cuclark — Unified CLI wrapper for CuCLARK GPU-accelerated metagenomic classifier.

Provides subcommands for classification, result summarization, database management,
and GPU auto-tuning. Uses only the Python standard library (no external deps).
"""

import argparse
import csv
import json
import os
import shutil
import subprocess
import sys
import textwrap
from collections import Counter
from datetime import datetime
from pathlib import Path

VERSION = "2.0.0"
ENGINE_VERSION = "1.1"

# ── GPU detection ──────────────────────────────────────────────────────────

def detect_gpus():
    """Query nvidia-smi for GPU info. Returns list of dicts or empty list."""
    try:
        result = subprocess.run(
            ["nvidia-smi",
             "--query-gpu=index,name,memory.total,memory.free",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            return []
        gpus = []
        for line in result.stdout.strip().splitlines():
            parts = [p.strip() for p in line.split(",")]
            if len(parts) >= 4:
                gpus.append({
                    "index": int(parts[0]),
                    "name": parts[1],
                    "mem_total": int(parts[2]),
                    "mem_free": int(parts[3]),
                })
        return gpus
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return []


def usable_gpus(gpus, min_free_mb=1024):
    """Filter GPUs with at least min_free_mb free VRAM."""
    return [g for g in gpus if g["mem_free"] >= min_free_mb]


# ── RAM detection ─────────────────────────────────────────────────────────

def detect_available_ram_mb():
    """Detect available system RAM in MB. Returns int or None on failure."""
    # Linux: read /proc/meminfo
    try:
        with open("/proc/meminfo") as f:
            for line in f:
                if line.startswith("MemAvailable:"):
                    kb = int(line.split()[1])
                    return kb // 1024
    except (FileNotFoundError, ValueError, IndexError):
        pass
    # macOS: use sysctl (reports total, not available — best effort)
    try:
        result = subprocess.run(
            ["sysctl", "-n", "hw.memsize"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0:
            return int(result.stdout.strip()) // (1024 * 1024)
    except (FileNotFoundError, subprocess.TimeoutExpired, ValueError):
        pass
    return None


# ── Helpers ────────────────────────────────────────────────────────────────

def find_binary(name):
    """Find a cuCLARK binary on PATH or in common locations."""
    path = shutil.which(name)
    if path:
        return path
    for d in ["/usr/local/bin", "/opt/cuclark/bin", "."]:
        candidate = os.path.join(d, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def banner(lines):
    """Print a banner with separator lines."""
    sep = "=" * 60
    print(sep)
    for line in lines:
        print(f"  {line}")
    print(sep)
    print(flush=True)


def error(msg):
    """Print error message and exit."""
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


def translate_exit_code(exit_code, stderr_text, batches):
    """Translate known error patterns into actionable messages."""
    if exit_code == 139:
        print("\nERROR: cuCLARK crashed (segmentation fault).", file=sys.stderr)
        print("  Try increasing --batches to reduce GPU memory pressure.", file=sys.stderr)
        if batches:
            print(f"  Current: --batches {batches}. Try: --batches {batches * 2}", file=sys.stderr)
    elif exit_code == 137:
        print("\nERROR: cuCLARK was killed (out of memory).", file=sys.stderr)
        print("  Try --light mode or increase --batches.", file=sys.stderr)
    elif "Batch overflow" in stderr_text:
        print("\nERROR: Batch overflow — GPU memory exceeded.", file=sys.stderr)
        if batches:
            print(f"  Increase --batches (current: {batches}). Try: --batches {batches * 2}", file=sys.stderr)
        else:
            print("  Try: --batches 4", file=sys.stderr)
    elif "less than 1GB" in stderr_text or "No CUDA" in stderr_text.lower():
        print("\nERROR: No usable GPU detected.", file=sys.stderr)
        print("  Ensure nvidia-docker runtime is configured (--gpus all).", file=sys.stderr)
    elif exit_code != 0:
        print(f"\nERROR: cuCLARK exited with code {exit_code}.", file=sys.stderr)


# ── Subcommand: classify ──────────────────────────────────────────────────

def auto_select_variant(usable, available_ram_mb=None):
    """Auto-select cuCLARK vs cuCLARK-l based on available RAM and VRAM.

    Primary factor is system RAM (full mode needs ~146 GB to build DB,
    ~40 GB to classify). VRAM only affects swap cycle count, not correctness.
    """
    # Primary check: system RAM
    if available_ram_mb is not None and available_ram_mb < 150000:
        return "light", f"auto (available RAM {available_ram_mb} MB < 150 GB)"
    if available_ram_mb is not None:
        return "full", f"auto (available RAM {available_ram_mb} MB >= 150 GB)"
    # Fallback: if RAM detection failed, use VRAM as heuristic
    if not usable:
        return "light", "auto (could not detect RAM or VRAM)"
    min_free = min(g["mem_free"] for g in usable)
    if min_free >= 8192:
        return "full", f"auto (RAM unknown, VRAM {min_free} MB >= 8 GB)"
    return "light", f"auto (RAM unknown, VRAM {min_free} MB < 8 GB)"


def cmd_classify(args):
    # GPU auto-detection (do this first — needed for variant selection)
    gpus = detect_gpus()
    usable = usable_gpus(gpus)

    devices = args.devices
    batches = args.batches
    threads = args.threads or 1

    if devices is None:
        if usable:
            devices = len(usable)
        else:
            error("No GPUs detected. Set --devices manually or ensure nvidia-docker is configured.")

    # Auto-select variant based on RAM and VRAM (unless user forced --light or --full)
    available_ram = detect_available_ram_mb()
    if args.light:
        light = True
        variant_reason = "user requested"
    elif args.full:
        light = False
        variant_reason = "user requested"
    else:
        selected, variant_reason = auto_select_variant(usable, available_ram)
        light = (selected == "light")

    binary_name = "cuCLARK-l" if light else "cuCLARK"
    binary = find_binary(binary_name)
    if not binary:
        error(f"Cannot find {binary_name}. Is it installed? Check PATH.")

    kmer = args.kmer_size or (27 if light else 31)

    if batches is None:
        batches = max(devices, threads)

    # Build command
    cmd = [binary, "-k", str(kmer), "-n", str(threads), "-b", str(batches), "-d", str(devices)]

    if args.reads:
        cmd.extend(["-O", args.reads])
    elif args.paired:
        cmd.extend(["-P", args.paired[0], args.paired[1]])

    cmd.extend(["-R", args.output])

    if args.targets:
        cmd.extend(["-T", args.targets])
    if args.db_dir:
        cmd.extend(["-D", args.db_dir])
    if args.sampling_factor is not None:
        cmd.extend(["-s", str(args.sampling_factor)])
    if args.extended:
        cmd.append("--extended")
    if args.tsk:
        cmd.append("--tsk")

    # Pre-run summary
    ram_str = f"{available_ram} MB" if available_ram is not None else "unknown"
    summary_lines = [
        f"cuCLARK {'light ' if light else ''}classification",
        f"Variant:   {binary_name} ({variant_reason})",
        f"RAM:       {ram_str} available",
        f"GPUs:      {devices} device(s)" + (f", min {min(g['mem_free'] for g in usable)} MB free VRAM" if usable else ""),
    ]
    for g in usable[:devices]:
        summary_lines.append(f"           [{g['index']}] {g['name']}")
    summary_lines.extend([
        f"k-mer:     {kmer}",
        f"Batches:   {batches}",
        f"Threads:   {threads}",
        f"Input:     {args.reads or ' '.join(args.paired or [])}",
        f"Output:    {args.output}",
    ])
    banner(summary_lines)

    # Run the binary
    print(f"Running: {' '.join(cmd)}\n", flush=True)
    sys.stdout.flush()
    sys.stderr.flush()
    result = subprocess.run(cmd)
    stderr_text = ""

    if result.returncode != 0:
        translate_exit_code(result.returncode, stderr_text, batches)
        sys.exit(result.returncode)

    # Metadata prepend
    results_csv = args.output + ".csv" if not args.output.endswith(".csv") else args.output
    if args.metadata and os.path.isfile(results_csv):
        now = datetime.now().isoformat(timespec="seconds")
        variant = "cuCLARK-l" if light else "cuCLARK"
        meta = (
            f"# cuclark classify {'--light ' if light else ''}\n"
            f"# date: {now}\n"
            f"# k={kmer}, devices={devices}, batches={batches}, threads={threads}\n"
            f"# variant: {variant}\n"
        )
        with open(results_csv, "r") as f:
            original = f.read()
        with open(results_csv, "w") as f:
            f.write(meta + original)
        print(f"\nMetadata prepended to {results_csv}")

    print("\nClassification complete.")


# ── Subcommand: summary ───────────────────────────────────────────────────

def cmd_summary(args):
    csv_path = args.results_csv
    if not os.path.isfile(csv_path):
        error(f"Results file not found: {csv_path}")

    min_conf = args.min_confidence
    top_n = args.top_n

    total = 0
    classified = 0
    unclassified = 0
    passing = 0
    taxa_counter = Counter()
    conf_buckets = {"<0.50": 0, "0.50-0.75": 0, "0.75-0.90": 0, ">=0.90": 0}

    with open(csv_path, "r", newline="") as f:
        for line in f:
            if line.startswith("#"):
                continue
            break
        # Re-read from start, skipping comments
        f.seek(0)
        lines = [l for l in f if not l.startswith("#")]

    if not lines:
        error("Results file is empty.")

    reader = csv.DictReader(lines)
    for row in reader:
        total += 1
        taxon = row.get("1st_assignment", "NA")
        conf_str = row.get("confidence", "0")
        try:
            conf = float(conf_str)
        except ValueError:
            conf = 0.0

        if taxon == "NA" or taxon == "":
            unclassified += 1
        else:
            classified += 1

        # Confidence buckets (all reads)
        if conf < 0.50:
            conf_buckets["<0.50"] += 1
        elif conf < 0.75:
            conf_buckets["0.50-0.75"] += 1
        elif conf < 0.90:
            conf_buckets["0.75-0.90"] += 1
        else:
            conf_buckets[">=0.90"] += 1

        # Apply min-confidence filter for taxa counting
        if conf >= min_conf and taxon != "NA" and taxon != "":
            passing += 1
            taxa_counter[taxon] += 1

    top_taxa = taxa_counter.most_common(top_n)

    # Output formats
    if args.krona:
        for taxon, count in top_taxa:
            print(f"{count}\t{taxon}")
        return

    if args.format == "json":
        result = {
            "total_reads": total,
            "classified": classified,
            "unclassified": unclassified,
            "min_confidence_filter": min_conf,
            "passing_filter": passing,
            "top_taxa": [{"taxon": t, "count": c} for t, c in top_taxa],
            "confidence_distribution": conf_buckets,
        }
        print(json.dumps(result, indent=2))
        return

    # Text output
    pct_c = (classified / total * 100) if total else 0
    pct_u = (unclassified / total * 100) if total else 0

    print("Classification Summary")
    print(f"  File:           {csv_path}")
    print(f"  Total reads:    {total}")
    print(f"  Classified:     {classified} ({pct_c:.1f}%)")
    print(f"  Unclassified:   {unclassified} ({pct_u:.1f}%)")

    if min_conf > 0:
        print(f"\n  Confidence filter: >= {min_conf}")
        print(f"  Passing filter:   {passing}")

    if top_taxa:
        print(f"\n  Top {min(top_n, len(top_taxa))} taxa:")
        max_name = max(len(t) for t, _ in top_taxa) if top_taxa else 10
        for taxon, count in top_taxa:
            pct = count / total * 100 if total else 0
            print(f"    {taxon:<{max_name}}  {count:>6}  ({pct:.1f}%)")

    print("\n  Confidence distribution:")
    max_count = max(conf_buckets.values()) if any(conf_buckets.values()) else 1
    for label, count in conf_buckets.items():
        bar_len = int(count / max_count * 30) if max_count else 0
        bar = "#" * bar_len
        print(f"    {label:>10}: {count:>6}  {bar}")


# ── Subcommand: download ──────────────────────────────────────────────────

def cmd_download(args):
    script = shutil.which("download_data.sh")
    if not script:
        for d in ["/opt/cuclark/scripts", "."]:
            candidate = os.path.join(d, "download_data.sh")
            if os.path.isfile(candidate):
                script = candidate
                break
    if not script:
        error("Cannot find download_data.sh. Ensure it is on PATH or in /opt/cuclark/scripts/.")

    for db in args.databases:
        print(f"\nDownloading {db} genomes to {args.db_dir}...")
        result = subprocess.run(["bash", script, args.db_dir, db])
        if result.returncode != 0:
            print(f"WARNING: download_data.sh exited with code {result.returncode} for {db}", file=sys.stderr)

    if args.taxonomy:
        tax_script = shutil.which("download_taxondata.sh")
        if not tax_script:
            for d in ["/opt/cuclark/scripts", "."]:
                candidate = os.path.join(d, "download_taxondata.sh")
                if os.path.isfile(candidate):
                    tax_script = candidate
                    break
        if tax_script:
            print(f"\nDownloading taxonomy data to {args.db_dir}...")
            subprocess.run(["bash", tax_script, args.db_dir])
        else:
            print("WARNING: download_taxondata.sh not found, skipping taxonomy download.", file=sys.stderr)

    print("\nDownload complete.")


# ── Subcommand: setup-db ──────────────────────────────────────────────────

def cmd_setup_db(args):
    script = shutil.which("set_targets.sh")
    if not script:
        for d in ["/opt/cuclark/scripts", "."]:
            candidate = os.path.join(d, "set_targets.sh")
            if os.path.isfile(candidate):
                script = candidate
                break
    if not script:
        error("Cannot find set_targets.sh. Ensure it is on PATH or in /opt/cuclark/scripts/.")

    cmd = ["bash", script, args.db_dir]
    cmd.extend(args.databases)
    if args.rank:
        cmd.extend(["--rank", args.rank])

    print(f"Setting up database targets in {args.db_dir}...")
    result = subprocess.run(cmd)
    if result.returncode != 0:
        error(f"set_targets.sh exited with code {result.returncode}")
    print("Database setup complete.")


# ── Subcommand: list-db ───────────────────────────────────────────────────

def cmd_list_db(args):
    db_dir = Path(args.db_dir)
    if not db_dir.is_dir():
        error(f"Database directory not found: {db_dir}")

    print(f"Database directory: {db_dir.resolve()}\n")

    # Check for genome directories
    genome_dirs = {}
    for name in ["bacteria", "viruses", "human", "custom"]:
        gdir = db_dir / name
        if gdir.is_dir():
            count = sum(1 for f in gdir.rglob("*.fna")) + sum(1 for f in gdir.rglob("*.fa")) + sum(1 for f in gdir.rglob("*.fasta"))
            genome_dirs[name] = count

    if genome_dirs:
        print("Downloaded genomes:")
        for name, count in genome_dirs.items():
            print(f"  {name:<15} {count:>6} genome(s)")
    else:
        print("Downloaded genomes: (none found)")

    # Check for built k-mer databases (cuCLARK uses .ht files)
    ht_files = list(db_dir.rglob("*.ht"))
    if ht_files:
        print("\nBuilt k-mer databases:")
        seen = set()
        for ht in ht_files:
            stem = ht.stem
            if stem not in seen:
                seen.add(stem)
                print(f"  {stem}")
    else:
        print("\nBuilt k-mer databases: (none found)")

    # Check for targets.txt
    targets = db_dir / "targets.txt"
    if targets.is_file():
        line_count = sum(1 for _ in open(targets))
        print(f"\ntargets.txt: present ({line_count} target(s))")
    else:
        # Also check parent or common locations
        found = False
        for p in [db_dir.parent / "targets.txt"]:
            if p.is_file():
                line_count = sum(1 for _ in open(p))
                print(f"\ntargets.txt: found at {p} ({line_count} target(s))")
                found = True
                break
        if not found:
            print("\ntargets.txt: not found")


# ── Subcommand: version ───────────────────────────────────────────────────

def cmd_version(args):
    print(f"cuclark wrapper version {VERSION}")
    print(f"CuCLARK engine version {ENGINE_VERSION}")

    # Check binaries
    for name in ["cuCLARK", "cuCLARK-l"]:
        path = find_binary(name)
        if path:
            print(f"\n{name}: {path}")
        else:
            print(f"\n{name}: not found")

    # GPU detection
    gpus = detect_gpus()
    if gpus:
        print(f"\nGPU(s) detected: {len(gpus)}")
        for g in gpus:
            print(f"  [{g['index']}] {g['name']} ({g['mem_total']} MiB total, {g['mem_free']} MiB free)")
    else:
        print("\nGPU(s) detected: 0 (nvidia-smi not available or no GPUs)")


# ── Main argument parser ──────────────────────────────────────────────────

def main():
    # Shell passthrough: support "cuclark bash" and "cuclark sh"
    if len(sys.argv) > 1 and sys.argv[1] in ("bash", "sh"):
        os.execvp(sys.argv[1], sys.argv[1:])

    parser = argparse.ArgumentParser(
        prog="cuclark",
        description="Unified CLI for CuCLARK GPU-accelerated metagenomic classifier.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Examples:
              cuclark classify --reads reads.fa --output results --targets targets.txt --db-dir db/ --light
              cuclark summary results.csv
              cuclark summary results.csv --format json
              cuclark summary results.csv --krona
              cuclark download --db-dir ./db bacteria viruses
              cuclark setup-db --db-dir ./db bacteria viruses
              cuclark list-db --db-dir ./db
              cuclark version
        """),
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # ── classify ──
    p_classify = subparsers.add_parser("classify", help="Run cuCLARK classification with GPU auto-tuning")
    input_group = p_classify.add_mutually_exclusive_group(required=True)
    input_group.add_argument("--reads", "-O", metavar="FILE", help="Input FASTA/FASTQ file")
    input_group.add_argument("--paired", "-P", nargs=2, metavar=("R1", "R2"), help="Paired-end read files")
    p_classify.add_argument("--output", "-R", required=True, metavar="FILE", help="Output CSV path (without .csv extension)")
    p_classify.add_argument("--targets", "-T", metavar="FILE", help="Targets definition file")
    p_classify.add_argument("--db-dir", "-D", metavar="DIR", help="Database directory")
    p_classify.add_argument("--kmer-size", "-k", type=int, metavar="INT", help="k-mer length (default: 31, or 27 for --light)")
    p_classify.add_argument("--threads", "-n", type=int, metavar="INT", help="CPU threads (default: 1)")
    p_classify.add_argument("--batches", "-b", type=int, metavar="INT", help="GPU batches (default: auto-detected)")
    p_classify.add_argument("--devices", "-d", type=int, metavar="INT", help="GPU device count (default: auto-detected)")
    variant_group = p_classify.add_mutually_exclusive_group()
    variant_group.add_argument("--light", action="store_true", help="Force cuCLARK-l (lighter, less VRAM)")
    variant_group.add_argument("--full", action="store_true", help="Force cuCLARK (full, more VRAM, faster)")
    # Default (neither flag): auto-select based on available VRAM
    p_classify.add_argument("--sampling-factor", "-s", type=int, metavar="INT", help="Sampling factor")
    p_classify.add_argument("--extended", action="store_true", help="Extended output with all target hit counts")
    p_classify.add_argument("--tsk", action="store_true", help="Create target-specific k-mer files")
    p_classify.add_argument("--metadata", action="store_true", help="Prepend run parameters as comments in output CSV")
    p_classify.set_defaults(func=cmd_classify)

    # ── summary ──
    p_summary = subparsers.add_parser("summary", help="Summarize classification results")
    p_summary.add_argument("results_csv", metavar="RESULTS.CSV", help="Path to results CSV file")
    p_summary.add_argument("--min-confidence", type=float, default=0.0, metavar="FLOAT",
                           help="Only count reads above this confidence (default: 0.0)")
    p_summary.add_argument("--top-n", type=int, default=10, metavar="INT", help="Show top N taxa (default: 10)")
    p_summary.add_argument("--format", choices=["text", "json"], default="text", help="Output format (default: text)")
    p_summary.add_argument("--krona", action="store_true", help="Output Krona-compatible TSV (count<TAB>taxon)")
    p_summary.set_defaults(func=cmd_summary)

    # ── download ──
    p_download = subparsers.add_parser("download", help="Download reference genomes from NCBI")
    p_download.add_argument("databases", nargs="+", choices=["bacteria", "viruses", "human"],
                            help="Databases to download")
    p_download.add_argument("--db-dir", required=True, metavar="DIR", help="Directory to store downloaded genomes")
    p_download.add_argument("--taxonomy", action="store_true", help="Also download NCBI taxonomy data")
    p_download.set_defaults(func=cmd_download)

    # ── setup-db ──
    p_setup = subparsers.add_parser("setup-db", help="Set up database targets")
    p_setup.add_argument("databases", nargs="+", choices=["bacteria", "viruses", "human", "custom"],
                         help="Databases to set up")
    p_setup.add_argument("--db-dir", required=True, metavar="DIR", help="Database directory")
    p_setup.add_argument("--rank", choices=["species", "genus", "family", "order", "class", "phylum"],
                         default="species", help="Taxonomy rank (default: species)")
    p_setup.set_defaults(func=cmd_setup_db)

    # ── list-db ──
    p_listdb = subparsers.add_parser("list-db", help="Inspect available databases")
    p_listdb.add_argument("--db-dir", required=True, metavar="DIR", help="Database directory")
    p_listdb.set_defaults(func=cmd_list_db)

    # ── version ──
    p_version = subparsers.add_parser("version", help="Show version and GPU info")
    p_version.set_defaults(func=cmd_version)

    # Parse and dispatch
    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)
    args.func(args)


if __name__ == "__main__":
    main()
